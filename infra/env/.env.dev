# Runtime profile
EXITPASS_RUNTIME_PROFILE=normal
ASPNETCORE_ENVIRONMENT=Development

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=exitpass
POSTGRES_USER=exitpass
POSTGRES_PASSWORD=exitpass_dev_password

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_DEFAULT_USER=exitpass
RABBITMQ_DEFAULT_PASS=exitpass_dev_password

# Central PMS
CENTRALPMS_HTTP_PORT=8080
CENTRALPMS_HTTPS_PORT=8443

# Connection strings
CONNECTIONSTRINGS__DEFAULT=Host=postgres;Port=5432;Database=exitpass;Username=exitpass;Password=exitpass_dev_password

# Logging
SERILOG__MINIMUMLEVEL__DEFAULT=Information
